# Токен от @BotFather (обязательно)
BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID администратора (куда приходят все новые записи)
# Можно оставить пустым: первый /start назначит админа автоматически
ADMIN_CHAT_ID=

# Порт API-сервера (сайт ходит на http://localhost:3001)
PORT=3001

# Имя бота без @ (для ссылок t.me/...)
BOT_USERNAME=elegiya_beauty_bot

# Разрешённые origins (через запятую). * — для локальной разработки
CORS_ORIGIN=*

# Прокси (если Telegram блокируется). Clash/v2rayN часто на 10809
HTTPS_PROXY=http://127.0.0.1:10809
HTTP_PROXY=http://127.0.0.1:10809
TELEGRAM_PROXY=http://127.0.0.1:10809
